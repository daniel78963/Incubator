<UserControl x:Class="Incubator.Desktop.Views.ConfiguracionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Left" Width="400">

            <ui:TextBlock FontTypography="Title" Text="Consumo de DLL Legacy (x86)" Margin="0,0,0,20"/>

            <ui:TextBlock Text="Valor de entrada numérico:" Margin="0,0,0,5" />

            <ui:TextBox Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}" 
                        Icon="{ui:SymbolIcon NumberSymbol24}"
                        PlaceholderText="Ej. 5"
                        Margin="0,0,0,15" />

            <ui:Button Content="Ejecutar Proceso Antiguo" 
                       Command="{Binding CalcularLegacyCommand}" 
                       Icon="{ui:SymbolIcon Play24}"
                       Appearance="Secondary"
                       Margin="0,0,0,20"/>

            <ui:Card>
                <StackPanel>
                    <ui:TextBlock Text="Resultado del proceso Fuera-de-Línea:" FontTypography="BodyStrong" Margin="0,0,0,10"/>
                    <ui:TextBlock Text="{Binding ResultText}" FontTypography="Body" TextWrapping="Wrap" />
                </StackPanel>
            </ui:Card>

            <ProgressBar IsIndeterminate="True" 
                            Margin="0,20,0,0"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisConverter}}" />
        </StackPanel>
    </Grid>
</UserControl>