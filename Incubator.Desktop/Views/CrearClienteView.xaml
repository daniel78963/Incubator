    <UserControl.Resources>
        <ControlTemplate x:Key="MyCustomErrorTemplate">
            <StackPanel>
                <Border BorderBrush="Red" BorderThickness="1.5" CornerRadius="3">
                    <AdornedElementPlaceholder Name="MyTextBoxPlaceholder"/>
                </Border>
                <TextBlock Text="{Binding ElementName=MyTextBoxPlaceholder, Path=AdornedElement.(Validation.Errors)[0].ErrorContent}"
                           Foreground="Red" FontSize="11" FontWeight="SemiBold" Margin="2,3,0,0"/>
            </StackPanel>
        </ControlTemplate>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MyCustomErrorTemplate}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Width="300" HorizontalAlignment="Left">
        <StackPanel>
            <TextBlock Text="Nuevo Cliente" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Nombre de la Empresa:" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Correo Electrónico:" />
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Guardar" Command="{Binding GuardarClienteCommand}" Padding="10,5" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>